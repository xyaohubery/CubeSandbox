# Template for the Tencent Cloud one-click deployer (create.sh / destroy.sh).
# Copy to `.env` and fill in real values. The resulting `.env` contains
# credentials (mode 600) and is gitignored — never commit it or ship it in a
# release bundle.
#
# These are the COMMON variables. Advanced toggles (e.g. TENCENTCLOUD_BUILD_IMAGES,
# TENCENTCLOUD_REINSTALL, TENCENTCLOUD_RESET_DB, per-image overrides, SSH key
# paths) are documented in the header comments of create.sh.

# --- Credentials (required) — create at https://console.cloud.tencent.com/cam/capi
TENCENTCLOUD_SECRET_ID='CHANGEME_SECRET_ID'
TENCENTCLOUD_SECRET_KEY='CHANGEME_SECRET_KEY'

# --- Region / zone (must match create.sh / variables.tf defaults: ap-guangzhou)
TENCENTCLOUD_VPC_NAME='cubesandbox-terraform-vpc'
TENCENTCLOUD_REGION='ap-guangzhou'
TENCENTCLOUD_AVAILABILITY_ZONE='ap-guangzhou-6'
# Optional: override per-role zones when stock varies by zone (same VPC).
# Leave unset to default each role to TENCENTCLOUD_AVAILABILITY_ZONE.
TENCENTCLOUD_JUMPSERVER_AVAILABILITY_ZONE='ap-guangzhou-6'
TENCENTCLOUD_COMPUTE_AVAILABILITY_ZONE='ap-guangzhou-6'
TENCENTCLOUD_TKE_WORKER_AVAILABILITY_ZONE='ap-guangzhou-6'

# --- Compute / image config
TENCENTCLOUD_IMAGE_NAME='OpenCloudOS Server 9'
TENCENTCLOUD_JUMPSERVER_INSTANCE_TYPE='SA9.MEDIUM4'
TENCENTCLOUD_COMPUTE_INSTANCE_TYPE='SA9.MEDIUM8'  # preferred type; actual per-node types are chosen at purchase time
TENCENTCLOUD_COMPUTE_NODE_COUNT='2'
# Optional: per compute-node CBS data disk size in GB (default 200). The disk is
# formatted as XFS and mounted at /data/cubelet on first boot.
# TENCENTCLOUD_COMPUTE_DATA_DISK_SIZE='200'
# Cubelet node status/resource reporting interval to CubeMaster.
TENCENTCLOUD_CUBELET_NODE_STATUS_UPDATE_FREQUENCY='10s'

# --- Passwords (CHANGE THESE for any non-throwaway deployment)
TENCENTCLOUD_MYSQL_PASSWORD='CHANGEME_MYSQL_PASSWORD'
TENCENTCLOUD_REDIS_PASSWORD='CHANGEME_REDIS_PASSWORD'
TENCENTCLOUD_CUBE_DB='cube_mvp'
TENCENTCLOUD_CUBE_USER='cube'
TENCENTCLOUD_CUBE_PASSWORD='CHANGEME_CUBE_PASSWORD'

# --- TKE / images
TENCENTCLOUD_USE_TCR='false'
TENCENTCLOUD_USE_CFS='false'
TENCENTCLOUD_CUBE_IMAGE_TAG='v0.5.0'
TENCENTCLOUD_IMAGE_REGISTRY='cube-sandbox-cn.tencentcloudcr.com'
TENCENTCLOUD_IMAGE_NAMESPACE='cube-sandbox'
TENCENTCLOUD_CUBEMASTER_IMAGE='cube-sandbox-cn.tencentcloudcr.com/cube-sandbox/cube-master:v0.5.0'
TENCENTCLOUD_CUBEAPI_IMAGE='cube-sandbox-cn.tencentcloudcr.com/cube-sandbox/cube-api:v0.5.0'
TENCENTCLOUD_CUBEPROXY_IMAGE='cube-sandbox-cn.tencentcloudcr.com/cube-sandbox/cube-proxy:v0.5.0'
TENCENTCLOUD_WEBUI_IMAGE='cube-sandbox-cn.tencentcloudcr.com/cube-sandbox/webui:v0.5.0'
TENCENTCLOUD_TKE_CLUSTER_VERSION='1.34.1'
TENCENTCLOUD_TKE_NODE_COUNT='2'
# Optional: TKE worker node instance type (defaults to SA9.LARGE8; leave unset to use the default).
# TENCENTCLOUD_TKE_WORKER_INSTANCE_TYPE='SA9.LARGE8'
# Optional: per-component replica counts (default 1). Raise/lower as needed.
# cubemaster_replicas also drives the conf's default_headless_service_nodes_num.
TENCENTCLOUD_CUBEMASTER_REPLICAS='1'
TENCENTCLOUD_CUBE_API_REPLICAS='1'
# cube-proxy defaults to 1 (single replica): auto-pause/auto-resume is only
# correct in single-replica mode. Setting >1 REQUIRES the front-end LB to hash
# on SandboxID (session affinity), otherwise auto-pause/auto-resume misfires.
TENCENTCLOUD_CUBE_PROXY_REPLICAS='1'
TENCENTCLOUD_CUBE_WEBUI_REPLICAS='1'
# Network exposure mode for cube-api / cube-proxy / cube-webui. Default 'false'
# fronts them with VPC-INTERNAL CLBs (private VIP only, reached via the
# jumpserver / VPN — no public exposure). Set to 'true' for PUBLIC CLBs
# reachable from the internet; read the "Hardening the Public-Facing Services"
# doc section before opting in. cube-master always stays VPC-internal.
TENCENTCLOUD_ENABLE_PUBLIC_NETWORK='false'
# Set to '0' to skip building images on the jumpserver and reuse already-pushed TCR images.
# TENCENTCLOUD_BUILD_IMAGES='1'

# --- Bundle / kernel (required for non-interactive runs that are NOT started
# from inside an already-extracted release bundle)
TENCENTCLOUD_LOCAL_BUNDLE=''
TENCENTCLOUD_PVM_KERNEL_VMLINUX='/root/Downloads/vmlinux-pvm'

# Verbose terraform logs. Interactive runs default to off (press Enter); a
# non-interactive run defaults to on unless you set this to 0.
TENCENTCLOUD_VERBOSE='1'
