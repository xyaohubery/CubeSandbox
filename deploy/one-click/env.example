# Recommended entrypoint:
#   ./deploy/one-click/build-release-bundle-builder.sh
# This wrapper compiles one-click component binaries inside the builder image,
# writes them into deploy/one-click/.work/prebuilt, then invokes
# build-release-bundle.sh on the host with ONE_CLICK_*_BIN overrides.
# Optional builder image override:
# BUILDER_IMAGE=cube-sandbox-builder:latest
#
# Builder-side options
ONE_CLICK_CUBEMASTER_BUILD_MODE=local
ONE_CLICK_CUBELET_BUILD_MODE=local
ONE_CLICK_CUBE_API_BUILD_MODE=local
ONE_CLICK_NETWORK_AGENT_BUILD_MODE=local
ONE_CLICK_CUBE_AGENT_BUILD_MODE=local
ONE_CLICK_CUBE_SHIM_BUILD_MODE=local

# Optional overrides for prebuilt binaries or fixed artifacts.
# ONE_CLICK_CUBEMASTER_BIN=/abs/path/to/cubemaster
# ONE_CLICK_CUBEMASTERCLI_BIN=/abs/path/to/cubemastercli
# ONE_CLICK_CUBELET_BIN=/abs/path/to/cubelet
# ONE_CLICK_CUBECLI_BIN=/abs/path/to/cubecli
# ONE_CLICK_CUBE_API_BIN=/abs/path/to/cube-api
# ONE_CLICK_NETWORK_AGENT_BIN=/abs/path/to/network-agent
# ONE_CLICK_CUBE_AGENT_BIN=/abs/path/to/cube-agent  # injected into guest image as /sbin/init
# ONE_CLICK_CUBESHIM_BIN=/abs/path/to/containerd-shim-cube-rs
# ONE_CLICK_CUBE_RUNTIME_BIN=/abs/path/to/cube-runtime
# ONE_CLICK_GUEST_IMAGE_DOCKERFILE=/abs/path/to/cube-sandbox/deploy/guest-image/Dockerfile
# ONE_CLICK_GUEST_IMAGE_CONTEXT_DIR=/abs/path/to/cube-sandbox/deploy/guest-image
# ONE_CLICK_GUEST_IMAGE_REF=cube-sandbox-guest-image:one-click
# ONE_CLICK_GUEST_IMAGE_VERSION=custom-guest-image-version
# ONE_CLICK_CUBE_KERNEL_VMLINUX=/abs/path/to/vmlinux
# Optional PVM guest kernel. When present, it is packaged as cube-kernel-scf/vmlinux-pvm.
# ONE_CLICK_CUBE_KERNEL_PVM_VMLINUX=/abs/path/to/vmlinux-pvm
# ONE_CLICK_RUNTIME_CFG_SRC=/abs/path/to/config-cube.toml

# Target-machine install options
ONE_CLICK_INSTALL_PREFIX=/usr/local/services/cubetoolbox
ONE_CLICK_RUN_QUICKCHECK=1
# Install the packaged PVM guest kernel as cube-kernel-scf/vmlinux.
# The default keeps the ordinary guest kernel.
CUBE_PVM_ENABLE=0
# Deployment role:
#   control - default all-in-one one-click node
#   compute - compute-only node that registers to an existing control plane
ONE_CLICK_DEPLOY_ROLE=control
# Required for compute role unless ONE_CLICK_CONTROL_PLANE_CUBEMASTER_ADDR is set.
# ONE_CLICK_CONTROL_PLANE_IP=10.0.0.11
# Optional explicit CubeMaster meta endpoint for compute role.
# ONE_CLICK_CONTROL_PLANE_CUBEMASTER_ADDR="${ONE_CLICK_CONTROL_PLANE_IP}:8089"

# Runtime and log directories on target host.
ONE_CLICK_RUNTIME_DIR=/var/run/cube-sandbox-one-click
ONE_CLICK_LOG_DIR=/var/log/cube-sandbox-one-click

# Dependency containers and credentials.
CUBE_SANDBOX_MYSQL_CONTAINER=cube-sandbox-mysql
CUBE_SANDBOX_REDIS_CONTAINER=cube-sandbox-redis
CUBE_SANDBOX_MYSQL_VOLUME=cube-sandbox-mysql-data
CUBE_SANDBOX_REDIS_VOLUME=cube-sandbox-redis-data
CUBE_SANDBOX_MYSQL_PORT=3306
CUBE_SANDBOX_REDIS_PORT=6379
CUBE_SANDBOX_REDIS_PASSWORD=ceuhvu123
CUBE_SANDBOX_MYSQL_ROOT_PASSWORD=cube_root
CUBE_SANDBOX_MYSQL_DB=cube_mvp
CUBE_SANDBOX_MYSQL_USER=cube
CUBE_SANDBOX_MYSQL_PASSWORD=cube_pass
# Optional: when unset, install.sh will try to auto-detect the IPv4 of eth0.
# CUBE_SANDBOX_NODE_IP=10.0.0.10
# Cubelet node registration will reuse CUBE_SANDBOX_NODE_IP when it is set.
# Compose fallback image for support services under /usr/local/services/cubetoolbox/support
# SUPPORT_COMPOSE_DOCKER_IMAGE=docker/compose:1.29.2

# Cube proxy options.
CUBE_PROXY_ENABLE=1
CUBE_PROXY_IMAGE_TAG=cube-proxy:one-click
CUBE_PROXY_CONTAINER_NAME=cube-proxy
CUBE_PROXY_HOST_PORT=443
CUBE_PROXY_CERT_DIR="${ONE_CLICK_INSTALL_PREFIX}/cubeproxy/certs"
CUBE_PROXY_REDIS_IP="${CUBE_SANDBOX_NODE_IP:-}"
CUBE_PROXY_DNS_ENABLE=1
CUBE_PROXY_DNS_ANSWER_IP="${CUBE_SANDBOX_NODE_IP:-}"
CUBE_PROXY_COREDNS_BIND_ADDR=127.0.0.54
CUBE_PROXY_RESOLVED_DNS_ADDR=169.254.254.53
CUBE_PROXY_COREDNS_CONTAINER=cube-proxy-coredns
# mkcert is bundled in the release package (support/bin/mkcert).
# Override with a custom binary path at build time if needed:
# ONE_CLICK_MKCERT_BIN=/abs/path/to/mkcert
# CUBE_PROXY_COMPOSE_DOCKER_IMAGE=docker/compose:1.29.2

# WebUI options.
WEB_UI_ENABLE=1
WEB_UI_IMAGE=cube-sandbox-image.tencentcloudcr.com/opensource/openresty:1.21.4.1-6-alpine-fat
WEB_UI_CONTAINER_NAME=cube-webui
WEB_UI_HOST_PORT=12088
WEB_UI_UPSTREAM=http://host.docker.internal:3000
# WEB_UI_COMPOSE_DOCKER_IMAGE=docker/compose:1.29.2
# Optional: reuse a prebuilt Vite dist directory when building the one-click bundle.
# ONE_CLICK_WEB_DIST_DIR=/abs/path/to/web/dist

# Process listen overrides.
CUBEMASTER_ADDR=127.0.0.1:8089
NETWORK_AGENT_HEALTH_ADDR=127.0.0.1:19090
NETWORK_AGENT_READY_TIMEOUT=120
CUBE_API_BIND=0.0.0.0:3000
CUBE_API_HEALTH_ADDR=127.0.0.1:3000
CUBE_API_SANDBOX_DOMAIN=cube.app
# AUTH_CALLBACK_URL=

# Optional Docker mirror.
ONE_CLICK_ENABLE_TENCENT_DOCKER_MIRROR=0
ONE_CLICK_TENCENT_DOCKER_MIRROR_URL=https://mirror.ccs.tencentyun.com
